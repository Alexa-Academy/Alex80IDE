<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:global="clr-namespace:"
        xmlns:views="clr-namespace:Alex80_IDE"
        xmlns:converters="clr-namespace:Alex80_IDE.Converters"
        x:Class="Alex80_IDE.MainWindow"
        x:DataType="global:MainViewModel"
        Title="Alex80 IDE"
        Width="1360"
        Height="930"
        MinWidth="1160"
        MinHeight="780"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Inter, Segoe UI, Helvetica Neue, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111318" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#181B22" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#20242D" />
        <SolidColorBrush x:Key="SurfaceInputBrush" Color="#14171D" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#313744" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F4FA" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#98A2B3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4CC9A7" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#2FAE8E" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E66767" />
        <SolidColorBrush x:Key="WarningBrush" Color="#EAB85F" />
        <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#332024" />
        <SolidColorBrush x:Key="DangerTextBrush" Color="#FFDCDC" />
        <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#1C3A35" />
        <StreamGeometry x:Key="MemoryIconData">M7,5 L7,3 L9,3 L9,5 L11,5 L11,3 L13,3 L13,5 L15,5 L15,3 L17,3 L17,5 L19,5 L19,7 L21,7 L21,9 L19,9 L19,11 L21,11 L21,13 L19,13 L19,15 L21,15 L21,17 L19,17 L19,19 L17,19 L17,21 L15,21 L15,19 L13,19 L13,21 L11,21 L11,19 L9,19 L9,21 L7,21 L7,19 L5,19 L5,17 L3,17 L3,15 L5,15 L5,13 L3,13 L3,11 L5,11 L5,9 L3,9 L3,7 L5,7 L5,5 Z M8,8 L8,16 L16,16 L16,8 Z M10,10 L14,10 L14,14 L10,14 Z</StreamGeometry>
        <StreamGeometry x:Key="SerialIconData">M4,5 L20,5 C21.1,5 22,5.9 22,7 L22,17 C22,18.1 21.1,19 20,19 L4,19 C2.9,19 2,18.1 2,17 L2,7 C2,5.9 2.9,5 4,5 Z M5,7 L5,17 L19,17 L19,7 Z M7,9 L10.5,12 L7,15 L8.3,16 L13,12 L8.3,8 Z M13,14 L17,14 L17,15.7 L13,15.7 Z</StreamGeometry>

        <global:HexadecimalConverter x:Key="HexadecimalConverter" />
        <converters:ByteToHexConverter x:Key="ByteToHexConverter" />
        <global:StartStopConverter x:Key="StartStopConverter" />
        <converters:EnableDisableConverter x:Key="EnableDisableConverter" />
        <global:BoolToDotConverter x:Key="BoolToDotConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.caption">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.memoryHeader">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.registerLabel">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.registerValue">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="Border.registerChip">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinWidth" Value="72" />
        </Style>

        <Style Selector="Border.cardBadge">
            <Setter Property="Background" Value="{StaticResource BadgeBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="MinWidth" Value="120" />
        </Style>

        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
        </Style>

        <Style Selector="Button.closeTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
        </Style>

        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="{StaticResource BorderSoftBrush}" />
        </Style>

        <Style Selector="ComboBox, TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="{StaticResource SurfaceInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
        </Style>

        <Style Selector="TextBox.codeEditor">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="ToggleSwitch">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TabControl.workspaceTabs">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TabControl.bottomToolTabs">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>

        <Style Selector="TabControl.bottomToolTabs > TabItem">
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="PathIcon.toolIcon">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style Selector="TabItem:selected PathIcon.toolIcon">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}" />
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Padding" Value="0,0,0,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Courier New" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            
        </Style>
        
        <Style Selector="DataGrid:focus-within DataGridColumnHeader,
                 DataGrid DataGridColumnHeader">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="DataGridCell TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="18" RowSpacing="14">
        <Border Grid.Row="0" Classes="panel">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Alex80 IDE"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Porta" Classes="caption" VerticalAlignment="Center" />
                    <ComboBox x:Name="PortsDropdown"
                              Width="210"
                              ItemsSource="{Binding PortsList}"
                              SelectedIndex="{Binding SelectedIdx, Mode=TwoWay}" />
                    <Button Content="{Binding ToggleButtonContent}"
                            Classes="primary"
                            Command="{Binding OpenCloseSerialPortCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Classes="cardBadge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CardBadgeText}"
                                   Classes="caption"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <ToggleSwitch Content="Clock Arduino"
                                  IsChecked="{Binding IsClockFromArduino, Mode=TwoWay}"
                                  IsEnabled="{Binding IsSerialOpened}" />
                    <ToggleSwitch Content="Mem Arduino"
                                  IsChecked="{Binding IsMemoryFromArduino, Mode=TwoWay}"
                                  IsEnabled="{Binding IsSerialOpened}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Classes="workspaceTabs">
            <TabItem Header="Editor / Load">
                <Grid RowDefinitions="Auto,*" RowSpacing="14" Margin="0,12,0,0">
                    <Border Classes="panel">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding NewTabCommand}" Content="Nuova" />
                                <Button Command="{Binding OpenFileCommand}" Content="Apri" />
                                <Button Command="{Binding SaveFileCommand}" Content="Salva" />
                                <Button Command="{Binding AssembleCommand}" Content="Assembla" Classes="primary" />
                                <Button Content="Carica bin" Click="LoadFileAsync" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Indirizzo" Classes="caption" VerticalAlignment="Center" />
                                <TextBox Text="{Binding AddressHex, Mode=TwoWay}" Width="82" Classes="mono" />
                                <TextBlock Text="Byte" Classes="caption" VerticalAlignment="Center" />
                                <TextBox Text="{Binding NumBytes}" Width="62" Classes="mono" />
                                <Button Content="Scrivi" Command="{Binding WriteMemoryCommand}" />
                            </StackPanel>

                            <ProgressBar Grid.Column="3"
                                         Minimum="0"
                                         Maximum="100"
                                         Width="180"
                                         Height="6"
                                         VerticalAlignment="Center"
                                         Value="{Binding ProgressValue}"
                                         IsVisible="{Binding ProgressVisible}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" RowDefinitions="*,6,260" RowSpacing="0">
                        <Border Classes="panel" Padding="0">
                            <Grid RowDefinitions="Auto,*">
                                <DockPanel Margin="14,14,14,10">
                                    <TextBlock Text="Sorgenti assembler" Classes="sectionTitle" DockPanel.Dock="Left" />
                                    <TextBlock Text="tab integrati" Classes="caption" DockPanel.Dock="Right" />
                                </DockPanel>

                                <TabControl Grid.Row="1"
                                            ItemsSource="{Binding OpenDocuments}"
                                            SelectedItem="{Binding SelectedDocument}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate x:DataType="global:DocumentViewModel">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding FileName}" />
                                                <Button Content="x"
                                                        Classes="closeTab"
                                                        Command="{Binding $parent[views:MainWindow].((global:MainViewModel)DataContext).CloseTabCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>

                                    <TabControl.ContentTemplate>
                                        <DataTemplate x:DataType="global:DocumentViewModel">
                                            <TextBox Text="{Binding Text, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     AcceptsTab="True"
                                                     TextWrapping="NoWrap"
                                                     Classes="codeEditor"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch" />
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="1"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ResizeDirection="Rows" />

                        <Border Grid.Row="2" Classes="panel" Padding="0" Margin="0,14,0,0">
                            <TabControl Classes="bottomToolTabs"
                                        TabStripPlacement="Left">
                                <TabItem>
                                    <TabItem.Header>
                                        <PathIcon Classes="toolIcon"
                                                  Data="{StaticResource MemoryIconData}"
                                                  ToolTip.Tip="Memoria" />
                                    </TabItem.Header>

                                    <Grid RowDefinitions="Auto,30,*">
                                        <DockPanel Margin="14,14,14,10">
                                            <TextBlock Text="Memoria pronta al caricamento" Classes="sectionTitle" DockPanel.Dock="Left" />
                                            <TextBlock Text="output assembler/binario" Classes="caption" Margin="12,0,0,0" DockPanel.Dock="Right" />
                                        </DockPanel>

                                        <Border Grid.Row="1"
                                                BorderBrush="{StaticResource BorderSoftBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="90,48,54,44,44,44,44,44,44,52,44,44,44,44,44,44,44,*">
                                                <TextBlock Grid.Column="0" Text="ADDR" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="1" Text="00" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="2" Text="01" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="3" Text="02" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="4" Text="03" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="5" Text="04" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="6" Text="05" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="7" Text="06" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="8" Text="07" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="9" Text="08" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="10" Text="09" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="11" Text="0A" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="12" Text="0B" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="13" Text="0C" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="14" Text="0D" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="15" Text="0E" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="16" Text="0F" Classes="memoryHeader" />
                                                <TextBlock Grid.Column="17" Text="ASCII" Classes="memoryHeader" />
                                            </Grid>
                                        </Border>

                                        <DataGrid Grid.Row="2"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding DataTable}"
                                                  RowHeight="30"
                                                  HeadersVisibility="None">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ADDR" Binding="{Binding Address, Converter={StaticResource HexadecimalConverter}}" Width="90" />
                                                <DataGridTextColumn Header="00" Binding="{Binding DataArray[0], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                                <DataGridTextColumn Header="01" Binding="{Binding DataArray[1], Converter={StaticResource ByteToHexConverter}}" Width="54" />
                                                <DataGridTextColumn Header="02" Binding="{Binding DataArray[2], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="03" Binding="{Binding DataArray[3], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="04" Binding="{Binding DataArray[4], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="05" Binding="{Binding DataArray[5], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="06" Binding="{Binding DataArray[6], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="07" Binding="{Binding DataArray[7], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="08" Binding="{Binding DataArray[8], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                                <DataGridTextColumn Header="09" Binding="{Binding DataArray[9], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0A" Binding="{Binding DataArray[10], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0B" Binding="{Binding DataArray[11], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0C" Binding="{Binding DataArray[12], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0D" Binding="{Binding DataArray[13], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0E" Binding="{Binding DataArray[14], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTextColumn Header="0F" Binding="{Binding DataArray[15], Converter={StaticResource ByteToHexConverter}}" Width="44" />
                                                <DataGridTemplateColumn Header="ASCII" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Ascii}"
                                                                       HorizontalAlignment="Left"
                                                                       TextAlignment="Left"
                                                                       VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>

                                <TabItem>
                                    <TabItem.Header>
                                        <PathIcon Classes="toolIcon"
                                                  Data="{StaticResource SerialIconData}"
                                                  ToolTip.Tip="Log seriale" />
                                    </TabItem.Header>

                                    <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="14">
                                        <TextBlock Text="Log seriale" Classes="sectionTitle" />
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding SerialMessageText}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 Classes="mono"
                                                 TextWrapping="NoWrap"
                                                 Name="EditorSerialBox"
                                                 TextChanged="SerialBox_TextChanged" />
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Debug">
                <Grid RowDefinitions="Auto,*" RowSpacing="14" Margin="0,12,0,0">
                    <Border Classes="panel">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Clock" Classes="caption" VerticalAlignment="Center" />
                                <TextBox Text="{Binding ClockFrequency}" Width="76" Classes="mono" />
                                <TextBlock Text="Hz" Classes="caption" VerticalAlignment="Center" />
                                <Button Content="{Binding IsClockActive, Converter={StaticResource StartStopConverter}}"
                                        Classes="primary"
                                        Command="{Binding StartStopBoardCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Reset"
                                        Classes="danger"
                                        Command="{Binding ResetCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="NMI"
                                        Command="{Binding SendNmiCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="{Binding DebugEnabled, Converter={StaticResource EnableDisableConverter}}"
                                        Command="{Binding DebugCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="Step"
                                        Command="{Binding StepCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="Dump registri"
                                        Command="{Binding DumpCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Log" Classes="caption" VerticalAlignment="Center" />
                                <Button Content="{Binding LogEnabled, Converter={StaticResource EnableDisableConverter}}"
                                        Command="{Binding EnableDisableLogsCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <ToggleSwitch Content="Autoscroll"
                                              IsChecked="{Binding IsAutoScrollEnabled, Mode=TwoWay}" />
                                <Button Content="Cancella log" Command="{Binding ClearLogsCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="14">
                        <Grid RowDefinitions="Auto,*" RowSpacing="14">
                            <Border Classes="panel">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Registri" Classes="sectionTitle" />
                                    <UniformGrid Columns="3" Rows="5">
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="A" Classes="registerLabel" /><TextBlock Text="{Binding ARegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="B" Classes="registerLabel" /><TextBlock Text="{Binding BRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,0,7"><StackPanel><TextBlock Text="C" Classes="registerLabel" /><TextBlock Text="{Binding CRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="D" Classes="registerLabel" /><TextBlock Text="{Binding DRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="E" Classes="registerLabel" /><TextBlock Text="{Binding ERegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,0,7"><StackPanel><TextBlock Text="H" Classes="registerLabel" /><TextBlock Text="{Binding HRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="L" Classes="registerLabel" /><TextBlock Text="{Binding LRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,7"><StackPanel><TextBlock Text="IX" Classes="registerLabel" /><TextBlock Text="{Binding IxRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,0,7"><StackPanel><TextBlock Text="IY" Classes="registerLabel" /><TextBlock Text="{Binding IyRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,0"><StackPanel><TextBlock Text="SP" Classes="registerLabel" /><TextBlock Text="{Binding SpRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip" Margin="0,0,7,0"><StackPanel><TextBlock Text="PC" Classes="registerLabel" /><TextBlock Text="{Binding PcRegHex}" Classes="registerValue" /></StackPanel></Border>
                                        <Border Classes="registerChip"><StackPanel><TextBlock Text="FLAGS" Classes="registerLabel" /><TextBlock Text="{Binding FlagsString}" Classes="registerValue" /></StackPanel></Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Classes="panel">
                                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                    <TextBlock Text="Seriale" Classes="sectionTitle" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding SerialMessageText}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             Classes="mono"
                                             TextWrapping="NoWrap"
                                             Name="DebugSerialBox"
                                             TextChanged="SerialBox_TextChanged" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1" RowDefinitions="*,230" RowSpacing="14">
                            <Border Classes="panel" Padding="0">
                                <Grid RowDefinitions="Auto,*">
                                    <DockPanel Margin="14,14,14,10">
                                        <TextBlock Text="Memoria" Classes="sectionTitle" DockPanel.Dock="Left" />
                                        <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right">
                                            <TextBlock Text="Indirizzo" Classes="caption" VerticalAlignment="Center" />
                                            <TextBox Text="{Binding AddressHex, Mode=TwoWay}" Width="82" Classes="mono" />
                                            <TextBlock Text="Byte" Classes="caption" VerticalAlignment="Center" />
                                            <TextBox Text="{Binding NumBytes}" Width="62" Classes="mono" />
                                            <Button Content="Leggi" Command="{Binding ReadMemoryCommand}" Classes="primary" />
                                            <Button Content="Scrivi" Command="{Binding WriteMemoryCommand}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <DataGrid Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              ItemsSource="{Binding DataTable}"
                                              RowHeight="30"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ADDR" Binding="{Binding Address, Converter={StaticResource HexadecimalConverter}}" Width="90" />
                                            <DataGridTextColumn Header="00" Binding="{Binding DataArray[0], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="01" Binding="{Binding DataArray[1], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="02" Binding="{Binding DataArray[2], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="03" Binding="{Binding DataArray[3], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="04" Binding="{Binding DataArray[4], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="05" Binding="{Binding DataArray[5], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="06" Binding="{Binding DataArray[6], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="07" Binding="{Binding DataArray[7], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="08" Binding="{Binding DataArray[8], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="09" Binding="{Binding DataArray[9], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0A" Binding="{Binding DataArray[10], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0B" Binding="{Binding DataArray[11], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0C" Binding="{Binding DataArray[12], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0D" Binding="{Binding DataArray[13], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0E" Binding="{Binding DataArray[14], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="0F" Binding="{Binding DataArray[15], Converter={StaticResource ByteToHexConverter}}" Width="52" />
                                            <DataGridTextColumn Header="ASCII" Binding="{Binding Ascii}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Classes="panel" Padding="0">
                                <Grid RowDefinitions="Auto,*">
                                    <DockPanel Margin="14,14,14,10">
                                        <TextBlock Text="Bus log" Classes="sectionTitle" DockPanel.Dock="Left" />
                                        <TextBlock Text="segnali e mnemonico" Classes="caption" DockPanel.Dock="Right" />
                                    </DockPanel>

                                    <DataGrid Grid.Row="1"
                                              RowHeight="30"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              ItemsSource="{Binding LogTable}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              HeadersVisibility="Column">
                                        <Interaction.Behaviors>
                                            <global:AutoScrollBehavior IsAutoScrollEnabled="{Binding IsAutoScrollEnabled}" />
                                        </Interaction.Behaviors>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ADDR" Binding="{Binding AddressHex}" Width="90" />
                                            <DataGridTextColumn Header="DATA" Binding="{Binding DataHex}" Width="76" />
                                            <DataGridTemplateColumn Header="RD" Width="54"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_RD, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="WR" Width="54"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_WR, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="IORQ" Width="62"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_IORQ, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="MREQ" Width="68"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_MREQ, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="RFSH" Width="64"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_RFSH, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="M1" Width="54"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Z80_M1, Converter={StaticResource BoolToDotConverter}}" FontSize="22" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="MNEMONICO" Binding="{Binding Mnemonic}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Monitor">
                <Grid RowDefinitions="Auto,*" RowSpacing="14" Margin="0,12,0,0">
                    <Border Classes="panel">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{Binding IsClockActive, Converter={StaticResource StartStopConverter}}"
                                        Classes="primary"
                                        Command="{Binding StartStopBoardCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="Reset"
                                        Classes="danger"
                                        Command="{Binding ResetCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                                <Button Content="NMI"
                                        Command="{Binding SendNmiCommand}"
                                        IsEnabled="{Binding IsSerialOpened}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Indirizzo" Classes="caption" VerticalAlignment="Center" />
                                <TextBox Text="{Binding AddressHex, Mode=TwoWay}" Width="82" Classes="mono" />
                                <TextBlock Text="Byte" Classes="caption" VerticalAlignment="Center" />
                                <TextBox Text="{Binding NumBytes}" Width="62" Classes="mono" />
                                <Button Content="Leggi" Command="{Binding ReadMemoryCommand}" Classes="primary" />
                                <Button Content="Scrivi" Command="{Binding WriteMemoryCommand}" />
                                <Button Content="Carica bin" Click="LoadFileAsync" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,470" ColumnSpacing="14">
                        <Border Classes="panel">
                            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                <TextBlock Text="Terminale seriale" Classes="sectionTitle" />
                                <TextBox Grid.Row="1"
                                         Text="{Binding SerialMessageText}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         Classes="mono"
                                         TextWrapping="NoWrap"
                                         Name="MonitorSerialBox"
                                         TextChanged="SerialBox_TextChanged" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Padding="0">
                            <Grid RowDefinitions="Auto,*">
                                <DockPanel Margin="14,14,14,10">
                                    <TextBlock Text="Memoria" Classes="sectionTitle" DockPanel.Dock="Left" />
                                    <TextBlock Text="lettura/scrittura rapida" Classes="caption" DockPanel.Dock="Right" />
                                </DockPanel>

                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding DataTable}"
                                          RowHeight="30"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ADDR" Binding="{Binding Address, Converter={StaticResource HexadecimalConverter}}" Width="90" />
                                        <DataGridTextColumn Header="00" Binding="{Binding DataArray[0], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="01" Binding="{Binding DataArray[1], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="02" Binding="{Binding DataArray[2], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="03" Binding="{Binding DataArray[3], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="04" Binding="{Binding DataArray[4], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="05" Binding="{Binding DataArray[5], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="06" Binding="{Binding DataArray[6], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="07" Binding="{Binding DataArray[7], Converter={StaticResource ByteToHexConverter}}" Width="48" />
                                        <DataGridTextColumn Header="ASCII" Binding="{Binding Ascii}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
